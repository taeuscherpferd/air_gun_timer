{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gun Timer",
  "version": "0.1.0",
  "identifier": "com.kaileanokeefe.guntimer",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gun Timer",
        "width": 420,
        "height": 820,
        "minWidth": 320,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
